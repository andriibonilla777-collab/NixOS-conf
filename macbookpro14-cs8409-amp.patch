+static inline unsigned int cs_8409_vendor_coef_get(struct hda_codec *codec, unsigned int idx)
+{
+        struct cs8409_apple_spec *spec = codec->spec;
+        unsigned int retval;
+        snd_hda_codec_read(codec, CS8409_VENDOR_NID, 0,
+                            AC_VERB_GET_COEF_INDEX, 0);
