+        retval = snd_hda_codec_read(codec, CS8409_VENDOR_NID, 0,
+                                  AC_VERB_GET_PROC_COEF, 0);
+        snd_hda_codec_write(codec, CS8409_VENDOR_NID, 0,
+                            AC_VERB_SET_COEF_INDEX, 0);
