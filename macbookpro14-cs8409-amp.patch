+// macbook pro subsystem ids
+// 14,1 0x106b3300
+// 14,2 0x106b3600
+// 14,3 0x106b3900
+
+// imac subsystem ids
+// 18,1 0x106b0e00
+// 18,2 0x106b0f00
+// 18,3 0x106b1000
