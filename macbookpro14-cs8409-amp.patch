+                cs_8409_disable_amp_tas576_amp0(codec);
+                cs_8409_disable_amp_tas576_amp1(codec);
+        }
+        else {
+                dev_info(hda_codec_dev(codec), "UNKNOWN subsystem id 0x%08x",codec->core.subsystem_id);
