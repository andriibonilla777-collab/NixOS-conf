+        cs_8409_linein_volume_mute(codec);
+
+        cs_8409_intmike_volume_unmute(codec);
+
+        cs_8409_linein_volume_unmute(codec);
+
+        cs_8409_inputs_power_nids_off(codec);
+
+}
