+        snd_hda_codec_write(codec, 0x03, 0, AC_VERB_SET_CHANNEL_STREAMID, 0x00000000); // 0x00370600
+//      snd_hda:     conv stream channel map 3 [('CHAN', 0), ('STREAMID', 0)]
