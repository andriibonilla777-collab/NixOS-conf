+
+        cs_8409_vendor_i2cRead(codec, 0x90, 0x1b7c, 1); // snd_hda
+        cs_8409_vendor_i2cRead(codec, 0x90, 0x1b7a, 1); // snd_hda
+        cs_8409_vendor_i2cWrite(codec, 0x90, 0x1b7a, 0x00dc, 1); // snd_hda
